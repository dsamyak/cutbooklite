generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique
  password_hash String
  name          String
  is_admin      Boolean        @default(false)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  salons        Salon[]
  barbers       Barber[]
  expenses      Expense[]
  subscription  Subscription?
}

model Salon {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id      String         @db.Uuid
  name          String
  address       String?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  owner         Owner          @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  salon_barbers SalonBarber[]
  services      Service[]
  expenses      Expense[]

  @@index([owner_id])
}

model Barber {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id      String         @db.Uuid
  email         String         @unique
  password_hash String
  name          String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  owner         Owner          @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  salon_barbers SalonBarber[]
  services      Service[]
}

model SalonBarber {
  salon_id  String   @db.Uuid
  barber_id String   @db.Uuid
  joined_at DateTime @default(now())
  salon     Salon    @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  barber    Barber   @relation(fields: [barber_id], references: [id], onDelete: Cascade)

  @@id([salon_id, barber_id])
}

model Service {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_id     String   @db.Uuid
  barber_id    String   @db.Uuid
  name         String
  price        Decimal  @db.Decimal(10, 2)
  payment_type String   // 'CASH' | 'UPI'
  service_date DateTime @db.Date
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  salon        Salon    @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  barber       Barber   @relation(fields: [barber_id], references: [id], onDelete: Cascade)

  @@index([salon_id])
  @@index([barber_id])
  @@index([service_date])
}

model Expense {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salon_id     String   @db.Uuid
  owner_id     String   @db.Uuid
  amount       Decimal  @db.Decimal(10, 2)
  category     String
  expense_date DateTime @db.Date
  note         String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  salon        Salon    @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  owner        Owner    @relation(fields: [owner_id], references: [id], onDelete: Cascade)

  @@index([salon_id])
  @@index([expense_date])
}

model Subscription {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id             String    @unique @db.Uuid
  status               String    // 'TRIAL' | 'ACTIVE' | 'GRACE' | 'LAPSED' | 'CANCELLED'
  plan_name            String
  billing_provider     String    @default("ADMIN")  // 'ADMIN' | 'RAZORPAY' | 'STRIPE'
  provider_sub_id      String?   // external payment reference if applicable
  notes                String?   // admin notes e.g. "Paid ₹2000 cash on 2026-06-01"
  current_period_start DateTime?
  current_period_end   DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt
  owner                Owner     @relation(fields: [owner_id], references: [id], onDelete: Cascade)
}
