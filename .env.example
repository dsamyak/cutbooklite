# ============================================================
# CutBook Lite — Environment Variables Reference
# Copy this file to .env and fill in the values.
# Never commit .env to source control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://cutbook_user:your_password_here@localhost:5432/cutbook_db"

# ── API Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── JWT / Auth ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_at_least_64_chars

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Subscription ─────────────────────────────────────────────
# Default trial period length in days (granted on owner registration)
TRIAL_PERIOD_DAYS=14

# ── Admin ────────────────────────────────────────────────────
# Bootstrap admin email — first login with this email gets admin access.
# Set securely; do NOT use a guessable address.
ADMIN_BOOTSTRAP_EMAIL=admin@cutbook.internal

# ── Frontend (Vite) ──────────────────────────────────────────
# Used in apps/web — must be prefixed with VITE_
VITE_API_URL=http://localhost:3000/v1
