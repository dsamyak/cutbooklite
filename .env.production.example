# ─── CutBook Lite — Production Environment Variables ───────────────────────────
# Copy this to .env and fill in your actual values
# Usage: docker compose --env-file .env up -d

# ─── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-48"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── App ──────────────────────────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000
FRONTEND_URL="https://yourdomain.com"
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"

# ─── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_xxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# ─── Storage (Cloudinary) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"

# ─── SMS Gateway (optional) ───────────────────────────────────────────────────
SMS_API_KEY=""
SMS_SENDER_ID="CUTBKL"

# ─── Local DB (only used in docker-compose.yml, not in prod override) ─────────
POSTGRES_PASSWORD="localdevpassword"
